# ─── Frontend (Vite) ───────────────────────────────────────────
# Full URL of your backend endpoint that sends leads to Telegram.
# In dev mode the Vite proxy forwards /api/* → localhost:5000 automatically.
# For production / ngrok set the full ngrok URL:
VITE_LEAD_API_URL=https://YOUR_NGROK_URL.ngrok-free.app/api/send-lead

# ─── Backend (Flask main.py) ────────────────────────────────────
# Telegram Bot token — get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Port for Flask server (default 5000)
PORT=5000
FLASK_DEBUG=1
